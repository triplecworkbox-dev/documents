<script>
    // Navigation functionality
    function showPage(pageName) {
        // Hide all pages
        document.querySelectorAll('.page').forEach(page => {
            page.classList.remove('active');
        });

        // Remove active class from all nav items
        document.querySelectorAll('.nav-item').forEach(item => {
            item.classList.remove('active');
        });

        // Show selected page
        let pageMap = {
            'home': 'home-page',
            'career': 'career-page', 
            'profile': 'profile-page',
            'badges': 'badges-page'
        };

        const targetPage = document.getElementById(pageMap[pageName]);
        if (targetPage) {
            targetPage.classList.add('active');
        }

        // Add active class to clicked nav item
        event.currentTarget.classList.add('active');

        // Special handling for motivation spark from profile
        if (pageName === 'profile') {
            // Add click handler to motivation card
            setTimeout(() => {
                const motivationCard = document.querySelector('.motivation-card');
                if (motivationCard) {
                    motivationCard.onclick = () => showMotivationPage();
                }
            }, 100);
        }
    }

    // Show motivation page
    function showMotivationPage() {
        document.querySelectorAll('.page').forEach(page => {
            page.classList.remove('active');
        });
        
        // Create motivation page if it doesn't exist
        let motivationPage = document.getElementById('motivation-page');
        if (!motivationPage) {
            // Already exists in HTML
        }
        
        document.getElementById('motivation-page').classList.add('active');
        
        // Update nav to show profile as active
        document.querySelectorAll('.nav-item').forEach(item => {
            item.classList.remove('active');
        });
        document.querySelectorAll('.nav-item')[2].classList.add('active'); // Profile tab
    }

    // Complete quest functionality
    function completeQuest(questId) {
        const questMessages = {
            1: "🎉 Leadership certificate uploaded successfully! You earned 150 XP and unlocked the 'Leadership Foundation' skill.",
            2: "📚 Strategic Planning course completed! You earned 200 XP and are now closer to mastering resource allocation.",
            3: "🎯 Change management project submitted! You earned 175 XP and demonstrated your transformation capabilities."
        };

        alert(questMessages[questId]);
        
        // Update XP (simulation)
        const currentXP = parseInt(document.querySelector('#profile-page .stat-value').textContent.replace(' XP', ''));
        const xpGains = { 1: 150, 2: 200, 3: 175 };
        const newXP = currentXP + xpGains[questId];
        
        // Update XP display
        document.querySelector('#profile-page .stat-value').textContent = `${newXP} XP`;
        
        // Calculate new progress percentage
        const newProgress = Math.min(((newXP - 1000) / 1500) * 100, 100);
        document.querySelector('#profile-page .progress-fill').style.width = `${newProgress}%`;
        
        // Update progress text
        const remaining = Math.max(2500 - newXP, 0);
        document.querySelector('#profile-page .progress-text').textContent = `${remaining} XP until Chief Visionary Officer`;
    }

    // Generate motivation
    function generateMotivation() {
        const motivations = [
            "Your leadership skills are growing stronger every day. Focus on mentoring a colleague this week to unlock your next achievement!",
            "You're 75% of the way to Chief Visionary Officer! Consider taking on a strategic project that showcases your vision.",
            "Your 24 completed projects show incredible dedication. Time to share your expertise and guide others to success.",
            "With 12 skills unlocked, you're becoming a well-rounded leader. What new challenge will you tackle next?",
            "Every successful manager started where you are. Your journey to executive leadership is uniquely yours - embrace it!",
            "Your consistent performance has brought you this far. Now it's time to think bigger and dream beyond your current role."
        ];

        const randomMotivation = motivations[Math.floor(Math.random() * motivations.length)];
        
        document.getElementById('motivation-text').textContent = randomMotivation;
        document.getElementById('motivation-result').style.display = 'block';
        
        // Scroll to show the result
        document.getElementById('motivation-result').scrollIntoView({ behavior: 'smooth' });
    }

    // Initialize progress bar animations on page load
    document.addEventListener('DOMContentLoaded', function() {
        setTimeout(() => {
            document.querySelectorAll('.progress-fill').forEach(bar => {
                bar.classList.add('animate');
            });
        }, 500);
    });

    // Handle motivation card click from profile
    document.addEventListener('DOMContentLoaded', function() {
        const motivationCard = document.querySelector('#profile-page .motivation-card');
        if (motivationCard) {
            motivationCard.style.cursor = 'pointer';
            motivationCard.onclick = () => showMotivationPage();
        }
    });
</script>

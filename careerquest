    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: #f5f5f7;
        min-height: 100vh;
        padding-bottom: 80px;
    }

    /* Container for mobile-like experience */
    .phone-container {
        max-width: 375px;
        margin: 20px auto;
        background: white;
        border-radius: 25px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        min-height: 90vh;
        position: relative;
    }

    /* Header */
    .header {
        background: white;
        padding: 15px 20px 10px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .logo {
        width: 24px;
        height: 24px;
        background: linear-gradient(135deg, #007AFF, #34C759);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 14px;
        font-weight: 600;
    }

    .app-name {
        font-size: 20px;
        font-weight: 600;
        color: #1d1d1f;
    }

    /* Main Content */
    .main-content {
        padding: 20px;
        min-height: calc(100vh - 160px);
    }

    /* Page Headers */
    .page-header {
        margin-bottom: 25px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #1d1d1f;
        margin-bottom: 5px;
    }

    .page-subtitle {
        font-size: 16px;
        color: #86868b;
    }

    /* Career Path Styles */
    .career-path {
        display: flex;
        flex-direction: column;
        gap: 0;
        position: relative;
    }

    .career-step {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px 0;
        position: relative;
    }

    .career-step:not(:last-child)::after {
        content: '';
        position: absolute;
        left: 30px;
        top: 80px;
        width: 2px;
        height: 40px;
        background: #e5e5e7;
    }

    .step-icon {
        width: 60px;
        height: 60px;
        border-radius: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        position: relative;
        flex-shrink: 0;
    }

    .step-icon.completed {
        background: linear-gradient(135deg, #34C759, #30D158);
    }

    .step-icon.current {
        background: linear-gradient(135deg, #FF9500, #FF6B00);
    }

    .step-icon.future {
        background: linear-gradient(135deg, #FF3B30, #FF6B6B);
    }

    .step-content {
        flex: 1;
    }

    .step-title {
        font-size: 18px;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 5px;
    }

    .step-description {
        font-size: 14px;
        color: #86868b;
        line-height: 1.4;
    }

    .completed-check {
        position: absolute;
        top: -5px;
        right: -5px;
        width: 20px;
        height: 20px;
        background: #34C759;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid white;
    }

    /* Profile Header */
    .profile-header {
        background: linear-gradient(135deg, #007AFF, #0056CC);
        padding: 30px 20px;
        margin: -20px -20px 25px -20px;
        text-align: center;
        color: white;
        border-radius: 0 0 25px 25px;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.2);
        border-radius: 40px;
        margin: 0 auto 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        border: 3px solid rgba(255,255,255,0.3);
    }

    .profile-name {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .profile-role {
        font-size: 16px;
        opacity: 0.9;
    }

    /* Stats Cards */
    .stats-grid {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #f0f0f0;
    }

    .stat-header {
        display: flex;
        justify-content: between;
        align-items: center;
        margin-bottom: 12px;
    }

    .stat-label {
        font-size: 16px;
        color: #86868b;
        flex: 1;
    }

    .stat-value {
        font-size: 20px;
        font-weight: 600;
        color: #007AFF;
    }

    /* Progress Bars */
    .progress-container {
        margin-top: 10px;
    }

    .progress-bar {
        width: 100%;
        height: 8px;
        background: #f0f0f0;
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.3s ease;
        background: linear-gradient(90deg, #007AFF, #FF6B00);
    }

    .progress-text {
        font-size: 14px;
        color: #86868b;
        margin-top: 8px;
        text-align: center;
    }

    /* Achievement Grid */
    .achievement-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-top: 20px;
    }

    .achievement-badge {
        background: white;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        border: 1px solid #f0f0f0;
        transition: transform 0.2s ease;
    }

    .achievement-badge:hover {
        transform: translateY(-2px);
    }

    .badge-icon {
        width: 50px;
        height: 50px;
        border-radius: 25px;
        margin: 0 auto 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .badge-icon.earned {
        background: linear-gradient(135deg, #FFD60A, #FF9500);
        color: white;
    }

    .badge-icon.locked {
        background: #f0f0f0;
        color: #86868b;
    }

    .badge-title {
        font-size: 14px;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 5px;
    }

    .badge-description {
        font-size: 12px;
        color: #86868b;
        line-height: 1.3;
    }

    .badge-locked .badge-title,
    .badge-locked .badge-description {
        opacity: 0.5;
    }

    /* Development targets */
    .development-targets {
        margin-top: 12px;
        padding-left: 0;
    }

    .target-item {
        font-size: 13px;
        color: #666;
        line-height: 1.4;
        margin-bottom: 6px;
        padding-left: 0;
    }

    .target-item:last-child {
        margin-bottom: 0;
    }

    /* Quest cards */
    .quest-section {
        margin-top: 25px;
    }

    .quest-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #f0f0f0;
        margin-bottom: 15px;
        display: flex;
        align-items: flex-start;
        gap: 15px;
    }

    .quest-icon {
        width: 40px;
        height: 40px;
        border-radius: 20px;
        background: linear-gradient(135deg, #34C759, #30D158);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .quest-content {
        flex: 1;
    }

    .quest-title {
        font-size: 16px;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 5px;
    }

    .quest-description {
        font-size: 14px;
        color: #86868b;
        line-height: 1.4;
        margin-bottom: 10px;
    }

    .quest-reward {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .xp-badge {
        background: linear-gradient(135deg, #FF9500, #FF6B00);
        color: white;
        padding: 4px 8px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }

    .quest-button {
        background: linear-gradient(135deg, #007AFF, #0056CC);
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    .quest-button:hover {
        transform: translateY(-1px);
    }
    .motivation-card {
        background: white;
        border-radius: 12px;
        padding: 25px 20px;
        text-align: center;
        border: 1px solid #f0f0f0;
        margin-top: 25px;
    }

    .motivation-icon {
        font-size: 24px;
        margin-bottom: 15px;
    }

    .motivation-title {
        font-size: 20px;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 10px;
    }

    .motivation-description {
        font-size: 16px;
        color: #86868b;
        line-height: 1.4;
        margin-bottom: 40px;
    }

    .motivation-prompt {
        font-size: 16px;
        color: #86868b;
        margin-bottom: 30px;
    }

    .generate-btn {
        background: linear-gradient(135deg, #007AFF, #0056CC);
        color: white;
        border: none;
        padding: 15px 30px;
        border-radius: 25px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    .generate-btn:hover {
        transform: translateY(-1px);
    }

    /* Bottom Navigation */
    .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 375px;
        background: white;
        border-top: 1px solid #f0f0f0;
        display: flex;
        padding: 12px 0 20px;
    }

    .nav-item {
        flex: 1;
        text-align: center;
        padding: 8px;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .nav-item.active {
        color: #007AFF;
    }

    .nav-item:not(.active) {
        color: #86868b;
    }

    .nav-icon {
        font-size: 20px;
        margin-bottom: 4px;
    }

    .nav-label {
        font-size: 12px;
        font-weight: 500;
    }

    /* Page visibility */
    .page {
        display: none;
    }

    .page.active {
        display: block;
    }

    /* Responsive */
    @media (max-width: 414px) {
        .phone-container {
            margin: 0;
            border-radius: 0;
            min-height: 100vh;
        }
    }

    /* Animation for progress bars */
    .progress-fill.animate {
        animation: fillProgress 2s ease-out;
    }

    @keyframes fillProgress {
        0% { width: 0%; }
    }
</style>
